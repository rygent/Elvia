{
  "name": "@elvia/ui",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./postcss.config": "./postcss.config.js",
    "./globals.css": "./src/styles/globals.css"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" --format=pretty",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --format=pretty",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit"
  },
  "license": "GPL-3.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rygent/Elvia.git",
    "directory": "packages/ui"
  },
  "dependencies": {
    "@elvia/utils": "workspace:^",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.7",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.10.5",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-formatter-pretty": "^7.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0"
}
